# apps/backend — environment template
# скопировать в .env и заполнить локальными значениями

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.0.0/16

# Database
DATABASE_URL=postgres://restos:restos@127.0.0.1:5432/restos_dev

# CORS (LAN-only)
CORS_ALLOWED_ORIGIN_REGEXES=^http://(192\.168|10\.|172\.(1[6-9]|2\d|3[0-1])|localhost|127\.0\.0\.1)

# Printer
PRINTER_VIRTUAL=True            # True — запись в PRINTER_OUTPUT_DIR вместо железа
PRINTER_OUTPUT_DIR=./printouts

# JWT
JWT_ACCESS_LIFETIME_HOURS=8
JWT_REFRESH_LIFETIME_DAYS=30

# PIN-сессия кассира
PIN_SESSION_TIMEOUT_MIN=30
