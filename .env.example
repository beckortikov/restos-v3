# RestOS v3 — корневой .env (для docker-compose)
# Скопировать: cp .env.example .env
# Затем: docker compose up -d

# ── Postgres ──
POSTGRES_USER=restos
POSTGRES_PASSWORD=restos
POSTGRES_DB=restos
POSTGRES_PORT=5432

# ── Backend ──
BACKEND_PORT=8000
DJANGO_SETTINGS_MODULE=config.settings.dev
# В проде сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-in-production-very-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# CORS для LAN-планшетов официантов
CORS_ALLOWED_ORIGIN_REGEXES=^http://(192\.168|10\.|172\.(1[6-9]|2\d|3[0-1])|localhost|127\.0\.0\.1)

# JWT-сессии
JWT_ACCESS_LIFETIME_HOURS=8
JWT_REFRESH_LIFETIME_DAYS=30
PIN_SESSION_TIMEOUT_MIN=30

# Принтеры (True = пишем в файл вместо железа, для демо/тестов)
PRINTER_VIRTUAL=True

# Авто-суперюзер при первом старте (поменяй пароль для продакшна!)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
